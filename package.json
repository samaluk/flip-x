{
  "name": "flip-x",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "confect:codegen": "confect codegen",
    "confect:dev": "confect dev",
    "dev": "portless",
    "dev:app": "next dev",
    "convex:dev": "convex dev",
    "convex:delete-preview": "node scripts/delete-convex-preview.mjs",
    "dev:stack": "convex dev --start 'pnpm dev'",
    "ci:local": "pnpm design:lint && pnpm lint && pnpm i18n:check && pnpm fallow:ci && pnpm test && pnpm build",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm lint:core && pnpm lint:tailwind",
    "lint:core": "oxlint . --ignore-path .oxlintignore",
    "lint:tailwind": "oxlint . --config .oxlintrc.tailwind.json --ignore-path .oxlintignore",
    "lint:fix": "pnpm lint:fix:core && pnpm lint:fix:tailwind",
    "lint:fix:core": "oxlint --fix . --ignore-path .oxlintignore",
    "lint:fix:tailwind": "oxlint --fix . --config .oxlintrc.tailwind.json --ignore-path .oxlintignore",
    "i18n:messages": "i18n-check --locales messages --source en --format next-intl --only missingKeys invalidKeys",
    "i18n:usage": "i18n-check --locales messages --source en --format next-intl --unused app shared game/cards --only undefined",
    "i18n:check": "pnpm i18n:messages && pnpm i18n:usage",
    "design:lint": "pnpm exec design.md lint DESIGN.md",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "vitest run --project engine --project infrastructure --project contract --project ui --project confect",
    "test:engine": "vitest run --project engine",
    "test:infra": "vitest run --project infrastructure",
    "test:contract": "vitest run --project contract",
    "test:ui": "vitest run --project ui",
    "test:confect": "vitest run --project confect",
    "test:smoke:backend": "bash scripts/convex-preview-test.sh pnpm vitest run --config vitest.convex.config.ts",
    "test:backend": "pnpm test:smoke:backend",
    "test:e2e": "bash scripts/convex-preview-test.sh pnpm playwright test",
    "test:vrt": "bash scripts/vrt-docker.sh",
    "test:vrt:update": "bash scripts/vrt-docker.sh --update",
    "fallow": "fallow",
    "fallow:baseline:update": "fallow dead-code --save-baseline fallow-baselines/dead-code.json || test $? -eq 1; fallow dupes --save-baseline fallow-baselines/dupes.json || test $? -eq 1; fallow health --save-baseline fallow-baselines/health.json || test $? -eq 1",
    "fallow:ci": "fallow audit --base origin/master --dead-code-baseline fallow-baselines/dead-code.json --health-baseline fallow-baselines/health.json --dupes-baseline fallow-baselines/dupes.json",
    "fallow:fix": "fallow fix",
    "doctor": "react-doctor",
    "doctor:diff": "react-doctor --diff --fail-on warning",
    "doctor:ci": "react-doctor --diff --fail-on warning --annotations --yes",
    "doctor:staged": "react-doctor --staged --fail-on warning --yes --project flip-x"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@confect/core": "9.2.1",
    "@confect/react": "9.2.1",
    "@confect/server": "9.2.1",
    "@convex-dev/migrations": "0.3.5",
    "@convex-dev/presence": "0.3.2",
    "@convex-dev/rate-limiter": "0.3.2",
    "@posthog/convex": "2.0.32",
    "@posthog/next": "0.8.0",
    "@sholajegede/convex-cascading-deletes": "0.1.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "convex": "1.42.1",
    "convex-helpers": "0.1.120",
    "effect": "3.21.4",
    "lucide-react": "1.23.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "next-intl": "4.13.1",
    "nuqs": "2.9.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "4.13.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "usehooks-ts": "3.1.1"
  },
  "devDependencies": {
    "@confect/cli": "9.2.1",
    "@confect/test": "9.2.1",
    "@effect/vitest": "0.29.0",
    "@google/design.md": "0.3.0",
    "@lingual/i18n-check": "0.9.5",
    "@playwright/test": "1.61.1",
    "@posthog/nextjs-config": "1.9.68",
    "@tailwindcss/postcss": "4.3.2",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript-7": "npm:typescript@7.0.2",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser": "4.1.10",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "convex-test": "0.0.54",
    "eslint-plugin-i18next": "6.1.5",
    "fallow": "3.2.0",
    "jsdom": "29.1.1",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tailwindcss": "1.3.5",
    "oxlint-tsgolint": "0.24.0",
    "portless": "0.15.1",
    "react-doctor": "0.7.2",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": "24.18.0"
  },
  "packageManager": "pnpm@11.11.0",
  "portless": {
    "name": "flip-x",
    "script": "dev:app"
  }
}
