{
  "name": "flip7",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "confect:codegen": "confect codegen",
    "confect:dev": "confect dev",
    "dev": "portless",
    "dev:app": "next dev",
    "convex:dev": "convex dev",
    "dev:stack": "convex dev --start 'pnpm dev'",
    "ci:local": "pnpm design:lint && pnpm lint && pnpm i18n:check && pnpm fallow:ci && pnpm test && pnpm build",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm lint:core && pnpm lint:tailwind",
    "lint:core": "oxlint . --ignore-path .oxlintignore",
    "lint:tailwind": "oxlint . --config .oxlintrc.tailwind.json --ignore-path .oxlintignore --threads=1",
    "lint:fix": "pnpm lint:fix:core && pnpm lint:fix:tailwind",
    "lint:fix:core": "oxlint --fix . --ignore-path .oxlintignore",
    "lint:fix:tailwind": "oxlint --fix . --config .oxlintrc.tailwind.json --ignore-path .oxlintignore --threads=1",
    "i18n:messages": "i18n-check --locales messages --source en --format next-intl --only missingKeys invalidKeys",
    "i18n:usage": "i18n-check --locales messages --source en --format next-intl --unused app shared game/cards --only undefined",
    "i18n:check": "pnpm i18n:messages && pnpm i18n:usage",
    "design:lint": "pnpm exec design.md lint DESIGN.md",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "vitest run --project engine --project infrastructure --project contract --project ui --project confect",
    "test:engine": "vitest run --project engine",
    "test:infra": "vitest run --project infrastructure",
    "test:contract": "vitest run --project contract",
    "test:ui": "vitest run --project ui",
    "test:confect": "vitest run --project confect",
    "test:smoke:backend": "bash scripts/convex-preview-test.sh pnpm vitest run --config vitest.convex.config.ts",
    "test:backend": "pnpm test:smoke:backend",
    "test:e2e": "bash scripts/convex-preview-test.sh pnpm playwright test",
    "test:vrt": "bash scripts/vrt-docker.sh",
    "test:vrt:update": "bash scripts/vrt-docker.sh --update",
    "fallow": "fallow",
    "fallow:baseline:update": "fallow dead-code --save-baseline fallow-baselines/dead-code.json || test $? -eq 1; fallow dupes --save-baseline fallow-baselines/dupes.json || test $? -eq 1; fallow health --save-baseline fallow-baselines/health.json || test $? -eq 1",
    "fallow:audit": "fallow audit --dead-code-baseline fallow-baselines/dead-code.json --health-baseline fallow-baselines/health.json --dupes-baseline fallow-baselines/dupes.json",
    "fallow:ci": "fallow dead-code --baseline fallow-baselines/dead-code.json && fallow dupes --baseline fallow-baselines/dupes.json && fallow health --baseline fallow-baselines/health.json",
    "fallow:fix": "fallow fix"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@confect/core": "6.0.0",
    "@confect/react": "6.0.0",
    "@confect/server": "6.0.0",
    "@convex-dev/migrations": "0.3.4",
    "@convex-dev/presence": "0.3.0",
    "@convex-dev/rate-limiter": "0.3.2",
    "@sholajegede/convex-cascading-deletes": "0.1.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "convex": "1.37.0",
    "convex-helpers": "0.1.116",
    "effect": "3.21.2",
    "lucide-react": "1.14.0",
    "motion": "12.38.0",
    "next": "16.2.6",
    "next-intl": "4.11.1",
    "nuqs": "2.8.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shadcn": "4.7.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@confect/cli": "6.0.0",
    "@confect/test": "6.0.0",
    "@effect/vitest": "0.29.0",
    "@google/design.md": "0.1.1",
    "@lingual/i18n-check": "0.9.5",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.4",
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260505.1",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "convex-test": "0.0.51",
    "eslint-plugin-i18next": "6.1.4",
    "fallow": "2.64.0",
    "jsdom": "29.1.1",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tailwindcss": "0.7.0",
    "oxlint-tsgolint": "0.22.1",
    "portless": "0.13.0",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@11.0.8",
  "portless": {
    "name": "flip7",
    "script": "dev:app"
  }
}
