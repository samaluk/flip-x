{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "ignorePatterns": [
    ".next/**",
    "node_modules/**",
    "coverage/**",
    "dist/**",
    "build/**",
    "convex/_generated/**",
    "public/**"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "plugins": ["typescript", "react", "jsx-a11y", "unicorn"],
  "rules": {
    "react/react-in-jsx-scope": "off"
  }
}
